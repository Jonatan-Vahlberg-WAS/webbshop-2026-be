{
  "name": "webbshop-2026-be",
  "version": "1.0.0",
  "description": "Webbshop backend - MEN stack (MongoDB, Express, Node.js)",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky",
    "seed": "node ./src/seeding/seeding.js"

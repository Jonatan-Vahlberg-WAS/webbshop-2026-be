  "keywords": [
    "men",
    "mongodb",
    "express",
    "nodejs"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-validator": "^7.3.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.5.0",
    "nodemailer": "^8.0.4"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "babel-jest": "^30.3.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "jest-mock-extended": "^4.0.0",
    "lint-staged": "^16.4.0",
    "mongodb-memory-server": "^11.0.1",
    "prettier": "3.8.1",
    "supertest": "^7.2.2",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  }
